# ────────────────────────────────────────────────────────────────────
# Copy this file to .env in the project root and fill in the values.
# The server loads variables from .env automatically via pydantic-settings.
# ────────────────────────────────────────────────────────────────────

# ── ASR (Faster-Whisper) ──────────────────────────────────────────────
# tiny / base / small / medium / large-v3
WHISPER_MODEL=base
# cpu or cuda
WHISPER_DEVICE=cuda
# int8 / float16 / float32
WHISPER_COMPUTE_TYPE=int8
# Language code: zh / en / ja / ko / … or "auto" for auto-detect
WHISPER_LANGUAGE=zh

# ── LLM ───────────────────────────────────────────────────────────────
# openai or ollama
LLM_PROVIDER=openai

# -- OpenAI (or compatible endpoint) --
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# -- Ollama (local) --
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── TTS ───────────────────────────────────────────────────────────────
# edge or sovits
TTS_PROVIDER=edge          
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
# When true, server voices status hints ("正在搜索...") before the final reply
SOVITS_BASE_URL=http://localhost:9880
TTS_STATUS_AUDIO=true
# ── Conversation ──────────────────────────────────────────────────────
# Chinese prompt (used when WHISPER_LANGUAGE=zh)
SYSTEM_PROMPT=你是 Alexa，一个友好、简洁的语音助手。用简短的口语化中文回答，不使用 Markdown 格式。
# English prompt (used when WHISPER_LANGUAGE=en)
SYSTEM_PROMPT_EN=You are Alexa, a friendly and concise voice assistant. Reply with plain spoken English only — no Markdown, lists, or special symbols. Keep replies to 1–3 sentences.
MAX_HISTORY_TURNS=10

# ── Search ────────────────────────────────────────────────────────────
SERPAPI_KEY=
SERPAPI_ENGINE=google

# ── Audio Logging ─────────────────────────────────────────────────────
# Set to true to save every uploaded audio clip as a WAV file for ASR analysis
SAVE_UPLOAD_AUDIO=false
SAVE_UPLOAD_AUDIO_DIR=audio_logs

# ── Client ────────────────────────────────────────────────────────────
SERVER_WS_URL=ws://localhost:8000/ws/audio
WAKE_WORD_KEYWORD=alexa
WAKE_WORD_THRESHOLD=0.5
WAKE_WORD_CONSECUTIVE_HITS=2
WAKE_WORD_COOLDOWN_SECONDS=1.0
SILENCE_THRESHOLD=300
SILENCE_SECONDS=1.5
MAX_RECORDING_SECONDS=15
STREAM_PLAYBACK=false
