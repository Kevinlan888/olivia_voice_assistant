# ────────────────────────────────────────────────────────────────────
# Copy this file to .env in the project root and fill in the values.
# The server loads variables from .env automatically via pydantic-settings.
# ────────────────────────────────────────────────────────────────────

# ── ASR (Faster-Whisper) ──────────────────────────────────────────────
# tiny / base / small / medium / large-v3
WHISPER_MODEL=base
# cpu / cuda / mlx
WHISPER_DEVICE=cuda
# int8 / float16 / float32 (ignored for mlx)
WHISPER_COMPUTE_TYPE=int8
# Language code: zh / en / ja / ko / … or "auto" for auto-detect
WHISPER_LANGUAGE=zh

# ── LLM ───────────────────────────────────────────────────────────────
# openai or ollama
LLM_PROVIDER=openai
# Enable streaming token output
LLM_STREAMING=true

# -- OpenAI (or compatible endpoint) --
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# -- Ollama (local) --
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── TTS ───────────────────────────────────────────────────────────────
# edge or sovits
TTS_PROVIDER=edge
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
SOVITS_BASE_URL=http://localhost:9880
# When true, server voices status hints ("正在搜索...") before the final reply
TTS_STATUS_AUDIO=true

# ── Conversation ──────────────────────────────────────────────────────
# Chinese prompt (used when WHISPER_LANGUAGE != en)
SYSTEM_PROMPT=你是 Olivia，一个友好、简洁、自然的中文语音助手。你的回答会被直接用于语音播报。请只输出适合朗读的纯文本口语句子，不使用 Markdown、标题、列表、编号、表情或特殊符号。优先直接回答用户问题，通常控制在 1 到 3 句。如果需要基于日期或时间做判断，请结合系统提供的当前时间信息。用户的输入来自语音识别（ASR），可能包含错别字、同音字替换、多字漏字或断句错误。请根据上下文自动推断用户的真实意图，不要纠正用户的措辞，直接回答推断后的问题。
# English prompt (used when WHISPER_LANGUAGE=en)
SYSTEM_PROMPT_EN=You are Olivia, a friendly and concise voice assistant. Your responses will be read aloud directly by a TTS engine. Reply with plain spoken English only — no Markdown, bullet points, headers, numbered lists, emojis, or special symbols. Be direct: give the answer first, then a brief clarification if needed. Keep replies to 1–3 sentences. If the user's question involves relative time expressions (today, tomorrow, now, etc.), use the current time provided by the system context. The user's input comes from speech recognition (ASR) and may contain misspellings, homophones, missing or extra words, or punctuation errors. Infer the user's true intent from context and answer accordingly — do not correct or point out transcription mistakes.
MAX_CONTEXT_TOKENS=8192
ENABLE_CONTEXT_SUMMARY=true

# ── Persistence ───────────────────────────────────────────────────────
ENABLE_PERSISTENCE=true
DB_PATH=data/conversations.db
SESSION_TIMEOUT_MINUTES=30

# ── Weather ───────────────────────────────────────────────────────────
# 高德地图 Web 服务 API Key
AMAP_KEY=

# ── Search ────────────────────────────────────────────────────────────
SERPAPI_KEY=
SERPAPI_ENGINE=google

# ── Agent Framework ───────────────────────────────────────────────────
AGENT_MAX_TOOL_ROUNDS=5
AGENT_ENABLE_TRACING=true

# ── Audio Logging ─────────────────────────────────────────────────────
# Set to true to save every uploaded audio clip as a WAV file for ASR analysis
SAVE_UPLOAD_AUDIO=false
SAVE_UPLOAD_AUDIO_DIR=audio_logs

# ── Client ────────────────────────────────────────────────────────────
SERVER_WS_URL=ws://localhost:8000/ws/audio
# Porcupine wake word — get your free key at https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=
WAKE_WORD_KEYWORD=porcupine
# Optional path to a custom .ppn keyword file (overrides WAKE_WORD_KEYWORD)
WAKE_WORD_KEYWORD_PATH=
WAKE_WORD_THRESHOLD=0.5
WAKE_WORD_COOLDOWN_SECONDS=1.0
SILERO_SPEECH_THRESHOLD=0.5
SILENCE_SECONDS=0.8
MIN_RECORDING_SECONDS=1.0
MAX_RECORDING_SECONDS=15
STREAM_PLAYBACK=true
# BCM 引脚号，-1 = 禁用（使用唤醒词模式）
PTT_GPIO_PIN=-1
# True = 上拉（按钮接 GND）
PTT_PULL_UP=true
# -1 = 系统默认音频输出设备
PLAYBACK_DEVICE_INDEX=-1
