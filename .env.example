# ────────────────────────────────────────────────────────────────────
# Copy this file to .env in the project root and fill in the values.
# The server loads variables from .env automatically via pydantic-settings.
# ────────────────────────────────────────────────────────────────────

# ── ASR (Faster-Whisper) ──────────────────────────────────────────────
WHISPER_MODEL=base          # tiny / base / small / medium / large-v3
WHISPER_DEVICE=cpu          # cpu or cuda
WHISPER_COMPUTE_TYPE=int8   # int8 / float16 / float32

# ── LLM ───────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama         # openai or ollama

# -- OpenAI (or compatible endpoint) --
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# -- Ollama (local) --
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── TTS ───────────────────────────────────────────────────────────────
TTS_PROVIDER=edge           # edge or sovits
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
SOVITS_BASE_URL=http://localhost:9880# When true, server voices status hints ("正在搜索...") before the final reply
TTS_STATUS_AUDIO=true
# ── Conversation ──────────────────────────────────────────────────────
SYSTEM_PROMPT=你是 Olivia，一个友好、简洁的语音助手。用简短的口语化中文回答，不使用 Markdown 格式。
MAX_HISTORY_TURNS=10

# ── Client ────────────────────────────────────────────────────────────
SERVER_WS_URL=ws://localhost:8000/ws/audio
PORCUPINE_ACCESS_KEY=      # https://console.picovoice.ai (free)
WAKE_WORD_KEYWORD=porcupine
SILENCE_THRESHOLD=300
SILENCE_SECONDS=1.5
MAX_RECORDING_SECONDS=15
